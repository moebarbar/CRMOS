# --- Core ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Supabase Postgres) ---
# Pooled connection for app code
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chiefos?schema=public&pgbouncer=true&connection_limit=1"
# Direct connection for migrations
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/chiefos?schema=public"

# --- Supabase (Storage + Realtime) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# --- Workflows (Inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Cache + Rate limit (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email (Resend transactional, Postmark inbound) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="ChiefOS <hello@chiefos.app>"
POSTMARK_INBOUND_SECRET=

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- AI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Voice ---
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- SMS / Voice (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=chiefos
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
